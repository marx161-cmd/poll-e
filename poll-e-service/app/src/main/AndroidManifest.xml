<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- IPC permission: only apps signed with the same key (PixelXpert fork) can receive suggestion broadcasts -->
    <permission
        android:name="com.termux.suggest.permission.POLL_E_IPC"
        android:protectionLevel="signature" />
    <uses-permission android:name="com.termux.suggest.permission.POLL_E_IPC" />

    <application
        android:label="Poll-E"
        android:allowBackup="false"
        android:supportsRtl="true">

        <service
            android:name=".PollEAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>
</manifest>
