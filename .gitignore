# Large local recovery/build state
recovery-*/
runtime-backup-*/

# LiteRT/Bazel generated links or outputs if a working tree is copied here
bazel-*
bazel-bin/
bazel-out/
bazel-testlogs/

# Model/runtime blobs
*.litertlm
*.gguf
*.tflite
*.onnx
*.bin
*.so
*.tar
*.zip

# Android jniLibs — packaged native worker + NPU dispatch libs
# (override the *.so block above for these specific paths)
!poll-e-service/app/src/main/jniLibs/
!poll-e-service/app/src/main/jniLibs/**/*.so
*.log
*.err
*.tmp
.DS_Store
