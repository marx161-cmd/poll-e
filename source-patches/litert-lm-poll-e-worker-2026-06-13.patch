+int FindMaxIndexSse2Float(const float* data, int size) {
+  if (size <= 0) return -1;
+  int max_idx = 0;
+  for (int i = 1; i < size; ++i) {
+    if (data[i] > data[max_idx]) max_idx = i;
+  }
+  return max_idx;
+}
+
+int FindMaxIndexSse2Int16(const int16_t* data, int size) {
+  if (size <= 0) return -1;
+  int max_idx = 0;
+  for (int i = 1; i < size; ++i) {
+    if (data[i] > data[max_idx]) max_idx = i;
+  }
+  return max_idx;
+}
